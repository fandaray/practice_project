# Скопируйте этот файл в .env и при необходимости измените значения.
# Все переменные необязательны - без .env используются значения по
# умолчанию из src/config.py, которые уже соответствуют заданию.

OPC_ENDPOINT=opc.tcp://0.0.0.0:4840/boiler/server/
OPC_ENDPOINT_CLIENT=opc.tcp://localhost:4840/boiler/server/
OPC_NAMESPACE_URI=http://example.org/boiler-scada

FLASK_HOST=0.0.0.0
FLASK_PORT=5050
FLASK_DEBUG=false

MODEL_STEP_SECONDS=1.0
HISTORY_LOG_INTERVAL_SECONDS=5.0

DB_FILE=../data/boiler_history.sqlite3
HISTORY_RETENTION_HOURS=24

LOG_LEVEL=INFO
